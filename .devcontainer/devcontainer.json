{
  "name": "AI_Bias CUDA",
  "build": { "dockerfile": "Dockerfile" },
  "runArgs": [
    "--gpus", "all",
    "--ipc=host"], // 解决 NCCL 报错
  "customizations": {
        "vscode": {
            "settings": {
                // 确保 VS Code 默认用配好的环境
                "python.defaultInterpreterPath": "/workspaces/AI_Bias/venv_bias/bin/python",
                "python.terminal.activateEnvInSelectedTerminal": true // 终端自动激活环境
            }
        }
    },
  "postStartCommand": "echo 'source /workspaces/AI_Bias/venv_bias/bin/activate' >> ~/.bashrc",
  "remoteUser": "root"
}
